__pycache__/
*.pyc
*.db
*.sqlite
.env
logs/
node_modules/
data/
# v3.28.2 — app/data/ is a static-content directory (chronicle.json), NOT
# the runtime DATA_DIR. The bare ``data/`` rule above is for SQLite databases
# and runtime state at /data; the app's static content must still be tracked.
!app/data/
!app/data/**
dev-data/
backups/
.claude/scheduled_tasks.lock
memory/

# Vault-symlinked project memory — absolute symlinks into
# /home/jason/lab/ai-context/mana-archive/ (the ai-context vault, its own
# repo). Tracking out-of-bounds symlinks is bad hygiene: fresh clones get
# dangling links and it's the ArgoCD repo-server failure class if ever
# rendered as manifests. Local symlinks stay for the vault workflow.
CLAUDE.md
current-status.md
roadmap.md
release-history.md
architecture.md
deployment.md

resend.txt

.env.cfaccess
.playwright-mcp.config.json
.playwright-mcp/
